{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "WorkoutLog": {
      "title": "Workout Log",
      "description": "A recorded workout session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "sessionName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "exerciseId": { "type": "string" },
              "exerciseName": { "type": "string" },
              "sets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reps": { "type": "number" },
                    "weight": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["userId", "sessionId", "date", "exercises"]
    },
    "WorkoutPlan": {
      "title": "Workout Plan",
      "description": "Customized workout plan for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "exercises": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "sets": { "type": "number" },
                    "reps": { "type": "string" },
                    "rest": { "type": "string" },
                    "buffer": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["userId", "sessions"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/workouts/{workoutId}": {
      "schema": "WorkoutLog",
      "description": "Logged workout sessions"
    },
    "/plans/{planId}": {
      "schema": "WorkoutPlan",
      "description": "User custom workout plans"
    }
  }
}
